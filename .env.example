# ASL Recognition Environment Configuration

# Pose Detection Settings
REACT_APP_POSENET_STRIDE=16
REACT_APP_POSENET_MULTIPLIER=0.5

# Confidence Thresholds
REACT_APP_KEYPOINT_MIN_CONFIDENCE=0.5
REACT_APP_SIGN_MIN_CONFIDENCE=0.6

# Video Settings
REACT_APP_VIDEO_WIDTH=640
REACT_APP_VIDEO_HEIGHT=480
REACT_APP_VIDEO_FPS=30

# Development
REACT_APP_DEBUG=false
REACT_APP_ENABLE_LOGGING=false
